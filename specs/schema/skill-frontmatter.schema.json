{
  "$id": "https://al4f.dev/schemas/skill-frontmatter.schema.json",
  "title": "SkillFrontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$",
      "maxLength": 64,
      "description": "Must match the skill directory name."
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1024,
      "description": "What the skill does and when agents should load it."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "author": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    }
  }
}
