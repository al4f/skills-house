{
  "name": "@skills-house/build",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Compile skills-house source skills to spec-compliant dist — npx @skills-house/build <skill-dir>",
  "author": "al4f <https://al4f.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/al4f/skills-house.git",
    "directory": "internal-scripts/build"
  },
  "homepage": "https://al4f.dev",
  "keywords": [
    "agent-skills",
    "skills-house",
    "build",
    "compiler"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/lib.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "build": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "validate": "tsc --noEmit",
    "test": "node --test test/build.test.mjs"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
